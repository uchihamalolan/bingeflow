{
	"name": "bingeflow",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox --mv3",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox --mv3",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox --mv3",
		"postinstall": "wxt prepare",
		"lint": "biome lint",
		"fmt": "biome format --write",
		"check": "biome check",
		"typecheck": "tsc --noEmit",
		"fix": "biome check --write"
	},
	"dependencies": {
		"defu": "^6.1.7",
		"svelte": "^5.53.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/chrome": "^0.1.43",
		"@wxt-dev/module-svelte": "^2.0.4",
		"open-props": "^1.7.23",
		"postcss-jit-props": "^1.0.16",
		"typescript": "~5.9.3",
		"wxt": "^0.20.26"
	}
