{
	"compilerOptions": {
		"target": "esnext",
		"moduleDetection": "force",
		"useDefineForClassFields": true,
		"module": "esnext",
		"moduleResolution": "bundler",

		"resolveJsonModule": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,

		"types": ["chrome", "vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
